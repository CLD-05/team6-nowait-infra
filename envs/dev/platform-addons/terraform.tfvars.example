# ========================================
# Common
# ========================================
team        = "team6"
project     = "nowait"
environment = "dev"
name_prefix = "team6-nowait-dev"
region      = "ap-northeast-2"

# IAM Role 생성 시 필수 permissions boundary
iam_role_permissions_boundary = "arn:aws:iam::194722398200:policy/TeamRuntimeBoundary"


# ========================================
# Target EKS Cluster
# ========================================

# Add-ons를 설치할 dev EKS Cluster 이름
cluster_name = "team6-nowait-dev-eks"


# ========================================
# EKS Add-ons
# ========================================

# EKS 기본 Add-on 목록
eks_addons = [
  "vpc-cni",
  "coredns",
  "kube-proxy",
  "eks-pod-identity-agent",
  "aws-ebs-csi-driver"
]

# Add-on 버전 고정이 필요하면 여기에 명시
# 비워두면 AWS/EKS가 클러스터 버전에 맞는 기본 호환 버전을 선택
addon_versions = {}

# EBS CSI Driver에 Pod Identity Role 연결
enable_ebs_csi_pod_identity = true

# ========================================
# Network
# ========================================

# dev/infra에서 생성된 VPC ID를 입력합니다.
#
# 확인 방법:
# cd envs/dev/infra
# terraform output vpc_id
vpc_id = "<DEV_VPC_ID>"


# ========================================
# Helm Chart Versions
# ========================================

# AWS Load Balancer Controller Helm chart version
lbc_chart_version = "1.13.0"

# metrics-server Helm chart version
metrics_server_chart_version = "3.12.2"

# External Secrets Operator Helm chart version
eso_chart_version = "0.14.4"

# Argo CD Helm chart version
enable_argocd        = true
argocd_chart_version = "9.5.9"
# argocd_values_file는 envs/dev/platform-addons/main.tf에서 path.module 기준으로
# 직접 하드코딩한다 (keda/karpenter/kube-prometheus-stack과 동일 패턴) — tfvars는
# path.module 표현식을 못 써서 여기서 상대경로를 주면 잘못된 위치를 가리킨다.


# ========================================
# External Secrets Operator / Pod Identity
# ========================================

enable_eso_pod_identity = true

# 확인 방법:
# cd envs/dev/infra
# terraform output secret_arns
# terraform output rds_master_user_secret_arn
external_secrets_secret_arns = [
  # module.secrets.secret_arns["api"]
  "arn:aws:secretsmanager:ap-northeast-2:194722398200:secret:team6-nowait/dev/api-xxxxxx",

  # module.secrets.secret_arns["redis"]
  "arn:aws:secretsmanager:ap-northeast-2:194722398200:secret:team6-nowait/dev/redis-xxxxxx",

  # module.database.master_user_secret_arn
  "arn:aws:secretsmanager:ap-northeast-2:194722398200:secret:rds!db-xxxxxx"
]

# ========================================
# KEDA
# ========================================
enable_keda        = true
keda_chart_version = "2.20.0"

# ========================================
# Karpenter
# ========================================
enable_karpenter        = true
karpenter_chart_version = "1.13.0"

# ========================================
# Monitoring
# ========================================
enable_kube_prometheus_stack        = true
kube_prometheus_stack_chart_version = "85.3.3"

# ========================================
# NoWait API Pod Identity
# ========================================

enable_nowait_api_pod_identity = true

nowait_api_namespace       = "nowait-dev"
nowait_api_service_account = "nowait-api-sa"

image_bucket_arn = "<IMAGE_BUCKET_ARN>"