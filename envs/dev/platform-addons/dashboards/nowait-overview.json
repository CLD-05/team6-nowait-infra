{
  "uid": "nowait-overview",
  "title": "NoWait Overview (dev)",
  "tags": ["nowait"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    { "id": 100, "type": "row", "title": "1순위 — API 응답시간 / 에러율 / 요청 수", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "id": 1,
      "title": "HTTP 요청 처리량 (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{namespace=\"nowait-dev\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP p95 레이턴시",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{namespace=\"nowait-dev\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 8,
      "title": "에러율 (5xx / 전체, %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(http_server_requests_seconds_count{namespace=\"nowait-dev\", status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{namespace=\"nowait-dev\"}[5m]))",
          "legendFormat": "error rate"
        }
      ]
    },

    { "id": 101, "type": "row", "title": "2순위 — Pod CPU / Memory / Restart / Replica", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 } },
    {
      "id": 2,
      "title": "CPU 사용률 (limit 대비 %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"nowait-dev\", container=~\"nowait-api|nowait-worker\"}[5m])) by (pod) / sum(kube_pod_container_resource_limits{namespace=\"nowait-dev\", resource=\"cpu\", container=~\"nowait-api|nowait-worker\"}) by (pod) * 100",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "메모리 사용률 (limit 대비 %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(container_memory_working_set_bytes{namespace=\"nowait-dev\", container=~\"nowait-api|nowait-worker\"}) by (pod) / sum(kube_pod_container_resource_limits{namespace=\"nowait-dev\", resource=\"memory\", container=~\"nowait-api|nowait-worker\"}) by (pod) * 100",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Pod 재시작 횟수 (최근 15분)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"nowait-dev\", container=~\"nowait-api|nowait-worker\"}[15m])",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "현재 Replica 수",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_deployment_status_replicas{namespace=\"nowait-dev\", deployment=~\"nowait-api|nowait-worker\"}",
          "legendFormat": "{{deployment}}"
        }
      ]
    },

    { "id": 102, "type": "row", "title": "3순위 — RDS / Redis 부하", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 } },
    {
      "id": 11,
      "title": "RDS CPU 사용률 (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
          "namespace": "AWS/RDS",
          "metricName": "CPUUtilization",
          "statistic": "Average",
          "dimensions": { "DBInstanceIdentifier": "team6-nowait-dev-rds" },
          "region": "ap-northeast-2",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "RDS DB 커넥션 수",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
          "namespace": "AWS/RDS",
          "metricName": "DatabaseConnections",
          "statistic": "Average",
          "dimensions": { "DBInstanceIdentifier": "team6-nowait-dev-rds" },
          "region": "ap-northeast-2",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Redis CPU 사용률 (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
          "namespace": "AWS/ElastiCache",
          "metricName": "CPUUtilization",
          "statistic": "Average",
          "dimensions": { "CacheClusterId": "team6-nowait-dev-redis-001" },
          "region": "ap-northeast-2",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "Redis 커넥션 수",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
          "namespace": "AWS/ElastiCache",
          "metricName": "CurrConnections",
          "statistic": "Average",
          "dimensions": { "CacheClusterId": "team6-nowait-dev-redis-001" },
          "region": "ap-northeast-2",
          "refId": "A"
        }
      ]
    },

    { "id": 103, "type": "row", "title": "4순위 — KEDA / Karpenter 확장 동작", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 } },
    {
      "id": 4,
      "title": "KEDA 현재 Replica 수",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"nowait-dev\", horizontalpodautoscaler=~\"keda-hpa-nowait-api|keda-hpa-nowait-worker\"}",
          "legendFormat": "{{horizontalpodautoscaler}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Redis Pending 큐 깊이 (worker KEDA 트리거 소스)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(waiting_queue_pending)",
          "legendFormat": "waiting pending"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(reservation_queue_pending)",
          "legendFormat": "reservation pending"
        }
      ]
    },
    {
      "id": 15,
      "title": "클러스터 전체 노드 수 (Karpenter 포함)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 52 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(kube_node_info)",
          "legendFormat": "node count"
        }
      ]
    },

    { "id": 104, "type": "row", "title": "5순위 — Alertmanager / Slack 알림", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 60 } },
    {
      "id": 7,
      "title": "현재 Firing 알림 수 (nowait-dev)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 61 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(ALERTS{alertstate=\"firing\", namespace=\"nowait-dev\"}) OR vector(0)",
          "legendFormat": "firing"
        }
      ]
    },
    {
      "id": 16,
      "title": "Firing 알림 목록",
      "type": "table",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 61 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ALERTS{alertstate=\"firing\", namespace=\"nowait-dev\"}",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
