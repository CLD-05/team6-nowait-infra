{
  "uid": "nowait-overview",
  "title": "NoWait Overview (dev)",
  "tags": ["nowait"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    { "id": 500, "type": "row", "title": "Row 0 — Service Overview / Health", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "id": 1, "title": "API Availability (up targets)", "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "green", "value": 1 }
      ] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(up{namespace=\"nowait-dev\", job=\"nowait-api\"})", "legendFormat": "api targets up" }]
    },
    {
      "id": 2, "title": "nowait-api Running Pods", "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "green", "value": 1 }
      ] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(kube_pod_status_phase{namespace=\"nowait-dev\", pod=~\"nowait-api-.*\", phase=\"Running\"})" }]
    },
    {
      "id": 3, "title": "nowait-worker Running Pods", "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "green", "value": 1 }
      ] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(kube_pod_status_phase{namespace=\"nowait-dev\", pod=~\"nowait-worker-.*\", phase=\"Running\"})" }]
    },
    {
      "id": 4, "title": "Pending Pods (cluster)", "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 }
      ] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(kube_pod_status_phase{phase=\"Pending\"}) OR vector(0)" }]
    },
    {
      "id": 5, "title": "Node Count", "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(kube_node_info)" }]
    },
    {
      "id": 6, "title": "Firing Alerts (nowait-dev)", "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 1 }
      ] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(ALERTS{alertstate=\"firing\", namespace=\"nowait-dev\"}) OR vector(0)" }]
    },
    {
      "id": 7, "title": "API Request Rate (RPS)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_server_requests_seconds_count{namespace=\"nowait-dev\"}[1m]))", "legendFormat": "total rps" }]
    },
    {
      "id": 8, "title": "5xx Error Rate (%)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }
      ] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * sum(rate(http_server_requests_seconds_count{namespace=\"nowait-dev\", status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{namespace=\"nowait-dev\"}[5m]))", "legendFormat": "error rate" }]
    },
    {
      "id": 9, "title": "p95 Latency", "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 1 }
      ] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{namespace=\"nowait-dev\"}[5m])) by (le))", "legendFormat": "p95" }]
    },
    {
      "id": 10, "title": "RDS CPU (CloudWatch)", "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }
      ] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "cloudwatch", "uid": "cloudwatch" }, "namespace": "AWS/RDS", "metricName": "CPUUtilization", "statistic": "Average", "dimensions": { "DBInstanceIdentifier": "team6-nowait-dev-rds" }, "region": "ap-northeast-2", "refId": "A" }]
    },
    {
      "id": 11, "title": "Redis CPU (CloudWatch)", "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }
      ] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "cloudwatch", "uid": "cloudwatch" }, "namespace": "AWS/ElastiCache", "metricName": "CPUUtilization", "statistic": "Average", "dimensions": { "CacheClusterId": "team6-nowait-dev-redis-001" }, "region": "ap-northeast-2", "refId": "A" }]
    },

    { "id": 501, "type": "row", "title": "Row 1 — API RED Metrics", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 } },
    {
      "id": 20, "title": "Request Rate by Endpoint", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_server_requests_seconds_count{namespace=\"nowait-dev\"}[1m])) by (uri)", "legendFormat": "{{uri}}" }]
    },
    {
      "id": 21, "title": "HTTP Status Code Distribution", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_server_requests_seconds_count{namespace=\"nowait-dev\"}[5m])) by (status)", "legendFormat": "{{status}}" }]
    },
    {
      "id": 22, "title": "4xx / 5xx Rate", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_server_requests_seconds_count{namespace=\"nowait-dev\", status=~\"4..\"}[5m]))", "legendFormat": "4xx" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_server_requests_seconds_count{namespace=\"nowait-dev\", status=~\"5..\"}[5m]))", "legendFormat": "5xx" }
      ]
    },
    {
      "id": 23, "title": "p50 / p95 / p99 Latency", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{namespace=\"nowait-dev\"}[5m])) by (le))", "legendFormat": "p50" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{namespace=\"nowait-dev\"}[5m])) by (le))", "legendFormat": "p95" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{namespace=\"nowait-dev\"}[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 24, "title": "Top 5 Slow Endpoints (p95)", "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "topk(5, histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{namespace=\"nowait-dev\"}[5m])) by (le, uri)))", "format": "table", "instant": true }]
    },
    {
      "id": 25, "title": "Top 5 Error Endpoints (5xx rate)", "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "topk(5, sum(rate(http_server_requests_seconds_count{namespace=\"nowait-dev\", status=~\"5..\"}[5m])) by (uri))", "format": "table", "instant": true }]
    },

    { "id": 502, "type": "row", "title": "Row 2 — NoWait Business Metrics", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 } },
    {
      "id": 30, "title": "TODO — Business Success/Failure Metrics Not Implemented", "type": "text",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 45 },
      "options": { "mode": "markdown", "content": "**아직 Spring Boot에 구현되지 않은 메트릭** — 이 Row는 의도적으로 비워둠 (없는 메트릭을 그려서 '항상 No data'인 패널을 만들지 않기 위함).\n\n구현 필요: `nowait_waiting_register_success_total`, `nowait_waiting_register_failure_total`, `nowait_reservation_success_total`, `nowait_reservation_failure_total`, `nowait_polling_requests_total`, `nowait_capacity_full_total`, `nowait_duplicate_waiting_attempt_total`. (Counter, MeterRegistry.counter 패턴으로 WaitingService/ReservationService에 추가)\n\n현재 실제로 존재하는 큐 깊이 지표(`waiting_queue_pending` 등)는 **Row 3 (Worker)** 에서 다룹니다 — 비즈니스 성공/실패가 아니라 워커 백로그 지표라서 분리했습니다." }
    },

    { "id": 503, "type": "row", "title": "Row 3 — Worker / Async Persistence", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 } },
    {
      "id": 40, "title": "Queue Pending (waiting / reservation)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 20 }, { "color": "red", "value": 50 }
      ] } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(waiting_queue_pending)", "legendFormat": "waiting pending" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(reservation_queue_pending)", "legendFormat": "reservation pending" }
      ]
    },
    {
      "id": 41, "title": "Queue Processing (in-flight)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(waiting_queue_processing)", "legendFormat": "waiting processing" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(reservation_queue_processing)", "legendFormat": "reservation processing" }
      ]
    },
    {
      "id": 42, "title": "Queue Dead-letter (worker failing if > 0)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 58 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 1 }
      ] } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(waiting_queue_deadletter)", "legendFormat": "waiting deadletter" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(reservation_queue_deadletter)", "legendFormat": "reservation deadletter" }
      ]
    },
    {
      "id": 43, "title": "Reservation No-show Candidates", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 58 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(reservation_noshow_candidates)", "legendFormat": "noshow candidates" }]
    },
    {
      "id": 44, "title": "Worker Pod CPU (% of limit)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 66 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"nowait-dev\", container=\"nowait-worker\"}[5m])) by (pod) / sum(kube_pod_container_resource_limits{namespace=\"nowait-dev\", resource=\"cpu\", container=\"nowait-worker\"}) by (pod) * 100", "legendFormat": "{{pod}}" }]
    },
    {
      "id": 45, "title": "Worker Pod Memory (% of limit)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 66 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(container_memory_working_set_bytes{namespace=\"nowait-dev\", container=\"nowait-worker\"}) by (pod) / sum(kube_pod_container_resource_limits{namespace=\"nowait-dev\", resource=\"memory\", container=\"nowait-worker\"}) by (pod) * 100", "legendFormat": "{{pod}}" }]
    },
    {
      "id": 46, "title": "Worker Pod Restarts (15m)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 74 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"nowait-dev\", container=\"nowait-worker\"}[15m])", "legendFormat": "{{pod}}" }]
    },
    {
      "id": 47, "title": "TODO — Persist Success/Failure/Lag/Retry", "type": "text",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 74 },
      "options": { "mode": "markdown", "content": "현재 큐 **깊이**만 보임 (pending/processing/deadletter) — 워커가 실제로 DB persist에 **성공/실패했는지, 얼마나 지연됐는지**는 메트릭이 없음.\n\n필요: `nowait_worker_persist_success_total`, `nowait_worker_persist_failure_total`, `nowait_worker_persist_lag_seconds`(Timer), retry count. `WaitingSyncHandler.sync()` / Reservation 동기화 핸들러에 Micrometer Counter/Timer 추가 필요." }
    },

    { "id": 504, "type": "row", "title": "Row 4 — Redis / ElastiCache", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 82 } },
    {
      "id": 50, "title": "Redis CPU % (CloudWatch)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 83 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "cloudwatch", "uid": "cloudwatch" }, "namespace": "AWS/ElastiCache", "metricName": "CPUUtilization", "statistic": "Average", "dimensions": { "CacheClusterId": "team6-nowait-dev-redis-001" }, "region": "ap-northeast-2", "refId": "A" }]
    },
    {
      "id": 51, "title": "Redis Connections (CloudWatch)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 83 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "cloudwatch", "uid": "cloudwatch" }, "namespace": "AWS/ElastiCache", "metricName": "CurrConnections", "statistic": "Average", "dimensions": { "CacheClusterId": "team6-nowait-dev-redis-001" }, "region": "ap-northeast-2", "refId": "A" }]
    },
    {
      "id": 52, "title": "Redis Memory Usage % (CloudWatch)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 91 },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }
      ] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "cloudwatch", "uid": "cloudwatch" }, "namespace": "AWS/ElastiCache", "metricName": "DatabaseMemoryUsagePercentage", "statistic": "Average", "dimensions": { "CacheClusterId": "team6-nowait-dev-redis-001" }, "region": "ap-northeast-2", "refId": "A" }]
    },
    {
      "id": 53, "title": "Redis Evictions (CloudWatch)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 91 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 1 }
      ] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "cloudwatch", "uid": "cloudwatch" }, "namespace": "AWS/ElastiCache", "metricName": "Evictions", "statistic": "Sum", "dimensions": { "CacheClusterId": "team6-nowait-dev-redis-001" }, "region": "ap-northeast-2", "refId": "A" }]
    },
    {
      "id": 54, "title": "Redis Cache Hits / Misses (CloudWatch)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 99 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "cloudwatch", "uid": "cloudwatch" }, "namespace": "AWS/ElastiCache", "metricName": "CacheHits", "statistic": "Sum", "dimensions": { "CacheClusterId": "team6-nowait-dev-redis-001" }, "region": "ap-northeast-2", "refId": "A" },
        { "datasource": { "type": "cloudwatch", "uid": "cloudwatch" }, "namespace": "AWS/ElastiCache", "metricName": "CacheMisses", "statistic": "Sum", "dimensions": { "CacheClusterId": "team6-nowait-dev-redis-001" }, "region": "ap-northeast-2", "refId": "B" }
      ]
    },
    {
      "id": 55, "title": "TODO — Redis Exporter Required", "type": "text",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 99 },
      "options": { "mode": "markdown", "content": "Redis exporter(`redis_exporter`)가 배포돼 있지 않아 **connected_clients 상세, expired_keys, 대기열 ZSET 크기, Lua 스크립트 에러**는 Prometheus로 못 봄.\n\n두 가지 방법:\n1. `redis_exporter` 사이드카 + ServiceMonitor 추가 (범용 Redis 지표)\n2. 앱 레벨에서 `nowait_redis_lua_error_total` Counter를 `WaitingRedisLuaExecutor`에 추가 (우리 도메인에 더 직접적)" }
    },

    { "id": 505, "type": "row", "title": "Row 5 — RDS / MySQL", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 107 } },
    {
      "id": 60, "title": "RDS CPU % (CloudWatch)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 108 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "cloudwatch", "uid": "cloudwatch" }, "namespace": "AWS/RDS", "metricName": "CPUUtilization", "statistic": "Average", "dimensions": { "DBInstanceIdentifier": "team6-nowait-dev-rds" }, "region": "ap-northeast-2", "refId": "A" }]
    },
    {
      "id": 61, "title": "RDS Connections (CloudWatch)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 108 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "cloudwatch", "uid": "cloudwatch" }, "namespace": "AWS/RDS", "metricName": "DatabaseConnections", "statistic": "Average", "dimensions": { "DBInstanceIdentifier": "team6-nowait-dev-rds" }, "region": "ap-northeast-2", "refId": "A" }]
    },
    {
      "id": 62, "title": "RDS Freeable Memory (CloudWatch)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 116 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [{ "datasource": { "type": "cloudwatch", "uid": "cloudwatch" }, "namespace": "AWS/RDS", "metricName": "FreeableMemory", "statistic": "Average", "dimensions": { "DBInstanceIdentifier": "team6-nowait-dev-rds" }, "region": "ap-northeast-2", "refId": "A" }]
    },
    {
      "id": 63, "title": "RDS Free Storage Space (CloudWatch)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 116 },
      "fieldConfig": { "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [
