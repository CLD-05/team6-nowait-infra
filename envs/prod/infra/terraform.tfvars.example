# ========================================
# Common
# ========================================
team        = "team6"
project     = "nowait"
environment = "prod"
name_prefix = "team6-nowait-prod"
region      = "ap-northeast-2"

# IAM Role 생성 시 필수 permissions boundary (본인 AWS 계정 ID로 변경 필요)
iam_role_permissions_boundary = "arn:aws:iam::194722398200:policy/TeamRuntimeBoundary"


# ========================================
# Network
# ========================================
vpc_cidr                 = "10.6.128.0/17"
az_count                 = 2
enable_dns_hostnames     = true
enable_dns_support       = true
public_subnet_cidrs      = ["10.6.128.0/24", "10.6.129.0/24"]
private_app_subnet_cidrs = ["10.6.144.0/20", "10.6.160.0/20"]
private_db_subnet_cidrs  = ["10.6.192.0/24", "10.6.193.0/24"]
nat_gateway_mode         = "per_az"


# ========================================
# EKS
# ========================================
eks_cluster_version         = "1.34"
node_desired_size           = 3
node_min_size               = 2
node_max_size               = 6
node_instance_types         = ["m6i.large"]
eks_endpoint_public_access  = false
eks_endpoint_private_access = true
eks_public_access_cidrs     = []
enabled_cluster_log_types   = ["api", "audit", "authenticator", "controllerManager", "scheduler"]

# EKS Access Entry 권한을 부여할 팀원들의 IAM User ARN 목록
admin_principal_arns = [
  "arn:aws:iam::194722398200:user/team6-YOUR-NAME-HERE",
  "arn:aws:iam::194722398200:user/team6-MEMBER-NAME-HERE"
]
developer_principal_arns = []
viewer_principal_arns    = []


# ========================================
# RDS & Redis & Bastion
# ========================================
db_engine_version            = "8.0"
db_name                      = "nowait"
db_master_username           = "admin"
db_instance_class            = "db.m7g.large"
db_allocated_storage         = 20
db_max_allocated_storage     = 200
db_multi_az                  = true
db_backup_retention          = 7
db_deletion_protection       = true
db_skip_final_snapshot       = false
db_final_snapshot_identifier = "team6-nowait-prod-rds-final-snapshot"
db_apply_immediately         = false

redis_node_type                = "cache.r7g.large"
redis_replica_count            = 1
redis_multi_az_enabled         = true
redis_automatic_failover       = true
redis_snapshot_retention_limit = 7

bastion_enabled       = true
bastion_instance_type = "t3.micro"


# ========================================
# S3 & CloudWatch
# ========================================
image_bucket_enabled    = true
frontend_bucket_enabled = false
cors_allowed_origins    = ["https://YOUR_DOMAIN_HERE"] # 실제 도메인 주소로 변경
log_retention_days      = 30


# ========================================
# Domain & Load Balancer (Route53 / ACM / ALB)
# ========================================
root_domain   = "YOUR_DOMAIN_HERE" # 예: nowait.singleuser.cloud
api_subdomain = "api"