# 공통 태그 및 이름 prefix
team        = "team6"
project     = "nowait"
environment = "prod"
name_prefix = "team6-nowait-prod"
region      = "ap-northeast-2"

# IAM Role 생성 시 필수 permissions boundary
iam_role_permissions_boundary = "arn:aws:iam::194722398200:policy/TeamRuntimeBoundary"

# Prod VPC CIDR
vpc_cidr = "10.6.128.0/17"

# AZ는 이름을 직접 쓰지 않고 개수만 지정
az_count = 2

# Public Subnet: ALB, NAT Gateway 위치
public_subnet_cidrs = [
  "10.6.128.0/24",
  "10.6.129.0/24"
]

# Private App Subnet: EKS Node, API Pod, Worker Pod 위치
private_app_subnet_cidrs = [
  "10.6.144.0/20",
  "10.6.160.0/20"
]

# Private DB Subnet: RDS, Redis 위치
private_db_subnet_cidrs = [
  "10.6.192.0/24",
  "10.6.193.0/24"
]

# Prod도 초기 비용을 고려해 single로 시작
# 비용 허용 시 per_az로 변경 가능
nat_gateway_mode = "single"

# Prod EKS Node Group
node_desired_size   = 2
node_min_size       = 2
node_max_size       = 8
node_instance_types = ["t3.large"]

# Prod는 private endpoint 중심으로 운영
eks_endpoint_public_access  = false
eks_endpoint_private_access = true
eks_public_access_cidrs     = []

# EKS 감사/추적 로그
enabled_cluster_log_types = [
  "api",
  "audit",
  "authenticator",
  "controllerManager",
  "scheduler"
]

# EKS Access Entry에 등록할 IAM User ARN
admin_principal_arns = [
  "arn:aws:iam::194722398200:user/<ADMIN_USER>"
]

developer_principal_arns = [
  "arn:aws:iam::194722398200:user/<DEVELOPER_USER>"
]

viewer_principal_arns = [
  "arn:aws:iam::194722398200:user/<VIEWER_USER>"
]

# Prod RDS: Multi-AZ로 DB HA 확보
db_instance_class      = "db.t4g.medium"
db_multi_az            = true
db_deletion_protection = true
db_skip_final_snapshot = false
db_backup_retention    = 7

# Prod Redis: Replication Group + Multi-AZ + Automatic Failover
redis_node_type          = "cache.t4g.medium"
redis_replica_count      = 1
redis_multi_az_enabled   = true
redis_automatic_failover = true

# Bastion은 SSM 전용으로 사용
bastion_enabled          = true
bastion_ssh_cidr_blocks = []

# Prod는 S3 + CloudFront로 React 정적 파일 배포
image_bucket_enabled    = true
frontend_bucket_enabled = true
cloudfront_enabled      = true

# Prod 로그 보관 기간
log_retention_days = 30
