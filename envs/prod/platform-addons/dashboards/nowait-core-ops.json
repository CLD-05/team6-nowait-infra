                "value": 0.9
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "사용률",
          "expr": "redis_memory_used_bytes / clamp_min(redis_memory_max_bytes, 1)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Redis Eviction 수",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 48
      },
      "description": "Eviction > 0 = 데이터 유실 위험(Redis가 실시간 상태 원천). redis_exporter(ElastiCache 연동) 실데이터.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(redis_evicted_keys_total[5m]))"
        }
      ]
    },
    {
      "type": "row",
      "title": "Kubernetes / 오토스케일링 / 배포 상태",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 55
      }
    },
    {
      "type": "timeseries",
      "title": "Deployment 가용 Replica",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 56
      },
      "description": "available < desired = 용량 저하 (실데이터).",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{deployment}} available",
          "expr": "kube_deployment_status_replicas_available{namespace=\"$namespace\",deployment=~\"nowait-.*\"}"
        },
        {
          "refId": "B",
          "legendFormat": "{{deployment}} desired",
          "expr": "kube_deployment_spec_replicas{namespace=\"$namespace\",deployment=~\"nowait-.*\"}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HPA 현재/목표 Replica",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 56
      },
      "description": "스케일링은 그 자체로 장애 아님. Pending Pod/지연/에러와 함께 볼 때 의미 (실데이터).",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{horizontalpodautoscaler}} current",
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"$namespace\"}"
        },
        {
          "refId": "B",
          "legendFormat": "{{horizontalpodautoscaler}} desired",
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=\"$namespace\"}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "노드 수 / Karpenter NodeClaim 수",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 56
      },
      "description": "전체 노드 수(kube_node_info)와 Karpenter 관리 노드 수(karpenter_cluster_state_node_count) — 둘 다 실데이터.",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "전체 노드 수",
          "expr": "count(kube_node_info)"
        },
        {
          "refId": "B",
          "legendFormat": "Karpenter 관리 노드",
          "expr": "karpenter_cluster_state_node_count"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pod 재시작 수",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 63
      },
      "description": "CrashLoop/불안정 신호 (실데이터). 15분 증가율.",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{pod}}",
          "expr": "sum(rate(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[15m])) by (pod) > 0"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "컨테이너 CPU 사용량",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 63
      },
      "description": "근본 원인 보조 지표 (주 SLI 아님).",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{pod}}",
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"$namespace\",container!=\"\"}[5m])) by (pod)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "컨테이너 메모리 사용량",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 63
      },
      "description": "근본 원인 보조 지표 (OOM 신호).",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{pod}}",
          "expr": "sum(container_memory_working_set_bytes{namespace=\"$namespace\",container!=\"\"}) by (pod)"
        }
      ]
    }
  ]
}