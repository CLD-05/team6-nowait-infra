# =============================================
# nowait-infra .gitignore
# Terraform 1.14.x (VPC, EKS, RDS, ElastiCache 등)
# IDE: IntelliJ IDEA + VS Code
# =============================================


# ==================
# Terraform
# ==================
# 로컬 상태 파일 (S3 backend 사용 → 로컬 불필요)
*.tfstate
*.tfstate.*
*.tfstate.backup

# 플랜 파일
*.tfplan
tfplan

# 자동 생성 디렉토리 및 락 파일
.terraform/
.terraform.lock.hcl

# 변수 파일 (credentials / endpoint 포함 가능)
*.tfvars
*.tfvars.json

# 단, 예시 파일은 커밋 (팀원 온보딩용)
!terraform.tfvars.example
!*.tfvars.example

# override 파일 (로컬 임시 수정용)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# crash log
crash.log
crash.*.log


# ==================
# 보안 / 인증 정보 (절대 커밋 금지)
# ==================
*.pem
*.key
*.p12
.env
.env.*
!.env.example

# AWS credentials
.aws/
credentials


# ==================
# IntelliJ IDEA
# ==================
.idea/
*.iws
*.iml
*.ipr


# ==================
# VS Code
# ==================
.vscode/
*.code-workspace


# ==================
# OS
# ==================
.DS_Store
.AppleDouble
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*~


# ==================
# 로그
# ==================
*.log
crash.log
