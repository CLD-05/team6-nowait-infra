# Terraform이 로컬에서 생성하는 작업 디렉터리
.terraform/

# Terraform state 파일은 S3 backend에 저장하므로 Git에 올리지 않음
*.tfstate
*.tfstate.*

# Terraform plan 파일
*.tfplan
tfplan

# Terraform crash log
crash.log
crash.*.log

# 로그 파일
*.log

# 로컬에서 임시로 덮어쓰는 Terraform 파일
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# .terraform.lock.hcl은 provider 버전 고정을 위해 커밋한다.
# backend.tf도 팀 공통 S3 backend 설정이므로 커밋한다.

# 팀원/환경별 실제 변수 파일은 Git에 올리지 않음
terraform.tfvars
*.tfvars.local

# 민감 정보 / 키 파일
*.pem
*.key
.env
.env.*

# 백업 파일
*.bak
*.backup

# OS / IDE 파일
.DS_Store
.idea/
.vscode/